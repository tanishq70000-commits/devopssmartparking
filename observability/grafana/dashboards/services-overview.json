{
  "title": "SmartParking - Services Overview",
  "uid": "smartparking-overview",
  "panels": [
    {
      "id": 1,
      "title": "Services Up/Down",
      "type": "stat",
      "targets": [{"expr": "up", "legendFormat": "{{job}}"}],
      "gridPos": {"h": 4, "w": 24, "x": 0, "y": 0}
    },
    {
      "id": 2,
      "title": "HTTP Request Rate",
      "type": "graph",
      "targets": [{"expr": "sum(rate(http_requests_total[5m])) by (job)", "legendFormat": "{{job}}"}],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4}
    },
    {
      "id": 3,
      "title": "HTTP Error Rate",
      "type": "graph",
      "targets": [{"expr": "sum(rate(http_requests_total{status=~\"5..\"}[5m])) by (job)", "legendFormat": "{{job}}"}],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4}
    },
    {
      "id": 4,
      "title": "P95 Response Time",
      "type": "graph",
      "targets": [{"expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, job))", "legendFormat": "{{job}}"}],
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 12}
    }
  ],
  "schemaVersion": 38,
  "version": 1
}